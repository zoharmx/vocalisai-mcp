# ─────────────────────────────────────────────────────────────────────────────
# VocalisAI MCP Server — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── VocalisAI Platform ───────────────────────────────────────────────────────
# Production Cloud Run URL (default already set — override only if self-hosting)
VOCALISAI_BASE_URL=https://your-cloud-run-service.run.app

# API key for authenticated endpoints (optional — leave empty for public endpoints)
VOCALISAI_API_KEY=

# HTTP client timeout in seconds
VOCALISAI_REQUEST_TIMEOUT=15.0

# ── MCP Transport ─────────────────────────────────────────────────────────────
# "stdio"  → for Claude Desktop / Cursor / Cline (default)
# "http"   → for remote HTTP clients / Docker deployment
MCP_TRANSPORT=stdio
MCP_PORT=8001

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
